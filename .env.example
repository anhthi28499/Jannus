# Path to the git clone on this machine (must exist; service runs git pull here)
REPO_PATH=/absolute/path/to/your/repo

# Bind address for uvicorn
HOST=0.0.0.0
PORT=8765

# GitHub webhook secret (Settings → Webhooks → Secret). Leave empty to skip verification (dev only).
WEBHOOK_SECRET=

# Optional: comma-separated GitHub event names (empty = all supported)
# EVENT_ALLOWLIST=push,issues,workflow_run

# Set true to only log prompts (no git pull / no claude) — useful when testing webhooks
WEBHOOK_DRY_RUN=false

# Claude Code CLI
CLAUDE_BIN=claude

# Optional: extra args after -p (space-separated). Example: --max-turns 20
# CLAUDE_EXTRA_ARGS=--max-turns 20

# Seconds
CLAUDE_TIMEOUT=600

# Optional: restrict which repos trigger (owner/repo, comma-separated). Empty = any
REPO_ALLOWLIST=
