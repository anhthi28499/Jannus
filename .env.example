# Persistent clones and checkpoints (default: ./workspaces under project root)
# WORKSPACES_DIR=/absolute/path/to/workspaces

HOST=0.0.0.0
PORT=8765

# GitHub webhook secret (empty = skip HMAC verification, dev only)
WEBHOOK_SECRET=

# EVENT_ALLOWLIST=push,issues,issue_comment,workflow_run
# REPO_ALLOWLIST=owner/repo

TRIGGER_KEYWORDS=/fix,/autofix,@jannus

WEBHOOK_DRY_RUN=false
MAX_ATTEMPTS=3

CLAUDE_BIN=claude
# CLAUDE_EXTRA_ARGS=--max-turns 20
CLAUDE_TIMEOUT=600

# OpenAI (planner + reviewer); optional but recommended
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LangSmith (set tracing on)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=jannus

# Telegram (human-in-the-loop notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional RAG: pip install -r requirements-rag.txt then:
RAG_ENABLED=false
